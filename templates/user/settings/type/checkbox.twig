<label for="{{ setting.name }}" class="form-label">{{ setting.label|trans }}</label>
<div class="d-flex gap-2">
    {% for optionName, optionLabel in setting.options %}
        <div class="form-check">
            <input type="checkbox" name="{{ setting.name }}[]" id="{{ setting.name }}_{{ optionName }}" value="{{ optionName }}" class="form-check-input" {% if optionName in setting.value %}checked{% endif %}/>
            <label class="form-check-label" for="{{ setting.name }}_{{ optionName }}">{{ optionLabel|trans }}</label>
        </div>
    {% endfor %}
</div>
