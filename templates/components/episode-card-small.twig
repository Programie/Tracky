{% set linkUrl = path("shows_season_page", {"show": episode.season.show.id, "number": episode.season.number}) ~ "#e" ~ episode.number %}
<div class="card">
    <a href="{{ linkUrl }}">
        <img class="card-img-top rounded-top image-wide" loading="lazy" src="{{ path("shows_episode_image", {"show": episode.season.show.id, "seasonNumber": episode.season.number, "episodeNumber": episode.number}) }}"/>
    </a>
    <div class="card-body">
        <h5 class="card-title text-truncate" title="{{ episode.season.number }}x{{ episode.number }} {{ episode.title|default("unknown-title"|trans) }}">
            <a class="text-reset text-decoration-none" href="{{ linkUrl }}"><b>{{ episode.season.number }}x{{ episode.number }}</b> {{ episode.title|default("unknown-title"|trans) }}</a>
        </h5>
        {% if withShowTitle|default(false) %}
            <div class="text-truncate" title="{{ episode.season.show.title }}"><a class="text-reset text-decoration-none" href="{{ path("shows_show_page", {"show": episode.season.show.id}) }}">{{ episode.season.show.title }}</a></div>
        {% endif %}
        {% if episode.runtime is not null %}
            <small class="d-block text-body-secondary"><i class="fa-solid fa-clock"></i> {{ "runtime"|trans({"%runtime%": episode.runtime}) }}</small>
        {% endif %}
        {% if episode.firstAired is not null %}
            <small class="d-block text-body-secondary"><i class="fa-solid fa-tower-cell"></i> {{ episode.firstAired|format_date }}</small>
        {% endif %}
    </div>
</div>
