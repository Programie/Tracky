{% set metadata = {"entry-type": entry.type, "entry-id": entry.id} %}

{% if entry.type == "episode" %}
    {% set episode = entry.episode %}
    {% set season = episode.season %}
    {% set show = season.show %}
    {% set imageUrl = path("shows_episode_image", {"show": show.id, "seasonNumber": season.number, "episodeNumber": episode.number}) %}
    {% set views = episode.viewsForUser(user) %}
    {% set metadata = metadata|merge({"views": views|length, "show": show.id, "season": season.number, "episode": episode.number}) %}
{% elseif entry.type == "movie" %}
    {% set movie = entry.movie %}
    {% set imageUrl = path("movies_get_image", {"movie": movie.id}) %}
    {% set views = movie.viewsForUser(user) %}
    {% set metadata = metadata|merge({"views": views|length, "movie": movie.id}) %}
{% endif %}

<div class="d-none" {% for key, value in metadata %} data-{{ key }}="{{ value }}"{% endfor %}></div>

<div class="card">
    <img class="card-img-top fullscreen-image" loading="lazy" src="{{ imageUrl }}"/>
    <div class="card-body">
        {% if entry.type == "episode" %}
            <h5 class="card-title text-truncate" title="{{ season.number }}x{{ episode.number }} {{ episode.title|default("unknown-title"|trans) }}"><a class="text-reset text-decoration-none" href="{{ path("shows_season_page", {"show": show.id, "number": season.number}) }}#e{{ episode.number }}"><b>{{ season.number }}x{{ episode.number }}</b> {{ episode.title|default("unknown-title"|trans) }}</a></h5>
            <div class="text-truncate" title="{{ show.title }}"><a class="text-reset text-decoration-none" href="{{ path("shows_show_page", {"show": show.id}) }}">{{ show.title }}</a></div>
        {% elseif entry.type == "movie" %}
            <h5 class="card-title text-truncate" title="{{ movie.title }}"><a class="text-reset text-decoration-none" href="{{ path("movies_single_page", {"movie": movie.id}) }}">{{ movie.title }}</a></h5>
        {% endif %}
        <div class="text-body-secondary">{{ entry.datetime|format_datetime }}</div>
    </div>
    {% if user == app.user %}
        <div class="card-footer">
            <button class="btn btn-sm history-edit-button" type="button" title="{{ "views.views"|trans({"%count%": views|length}) }}"><i class="fa-solid fa-check"></i></button>
        </div>
    {% endif %}
</div>
