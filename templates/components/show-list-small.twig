<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
    {% for show in shows %}
        {% if not (
            ("ended" in hideShows and show.status == "ended") or
            ("finished" in hideShows and show.getWatchProgress(watchStatsProvider) == 100) or
            ("unwatched" in hideShows and show.getWatchProgress(watchStatsProvider) == 0)
        ) %}
            <div class="col">
                {% include "components/show-card-small.twig" with {"show": show} %}
            </div>
        {% endif %}
    {% endfor %}
</div>
