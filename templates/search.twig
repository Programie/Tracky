{% extends "page.twig" %}

{% block title %}{{ "search.title"|trans }}{% endblock %}

{% block content %}
    <form method="get" role="search">
        <input class="form-control" type="search" name="query" value="{{ query }}" placeholder="{{ "search.placeholder"|trans }}"/>
    </form>

    {% if results is not null %}
        {% if results %}
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4 mt-1">
                {% for entry in results %}
                    {% if entry.className == "Episode" %}
                        {% set imageUrl = path("shows_episode_image", {"show": entry.season.show.id, "seasonNumber": entry.season.number, "episodeNumber": entry.number}) %}
                    {% elseif entry.className == "Movie" %}
                        {% set imageUrl = path("movies_get_image", {"movie": entry.id}) %}
                    {% elseif entry.className == "Show" %}
                        {% set imageUrl = path("shows_show_image", {"show": entry.id}) %}
                    {% endif %}
                    <div class="col">
                        <div class="card">
                            <img class="card-img-top fullscreen-image" loading="lazy" src="{{ imageUrl }}"/>
                            <div class="card-body">
                                {% if entry.className == "Episode" %}
                                    <h5 class="card-title text-truncate" title="{{ entry.season.number }}x{{ entry.number }} {{ entry.title }}"><a class="text-reset text-decoration-none" href="{{ path("shows_season_page", {"show": entry.season.show.id, "number": entry.season.number}) }}#e{{ entry.number }}"><b>{{ entry.season.number }}x{{ entry.number }}</b> {{ entry.title }}</a></h5>
                                    <div class="text-truncate" title="{{ entry.season.show.title }}"><a class="text-reset text-decoration-none" href="{{ path("shows_show_page", {"show": entry.season.show.id}) }}">{{ entry.season.show.title }}</a></div>
                                {% elseif entry.className == "Movie" %}
                                    <h5 class="card-title text-truncate" title="{{ entry.title }}"><a class="text-reset text-decoration-none" href="{{ path("movies_single_page", {"movie": entry.id}) }}">{{ entry.title }}</a></h5>
                                {% elseif entry.className == "Show" %}
                                    <h5 class="card-title text-truncate" title="{{ entry.title }}"><a class="text-reset text-decoration-none" href="{{ path("shows_show_page", {"show": entry.id}) }}">{{ entry.title }}</a></h5>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="alert alert-warning mt-3">{{ "search.no-results"|trans({"%query%": query}) }}</div>
        {% endif %}
    {% endif %}
{% endblock %}
