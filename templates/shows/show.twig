{% extends "page.twig" %}

{% block title %}{{ show.title }}{% endblock %}

{% macro navItem(path, parameters, title) %}
    <li class="nav-item">
        <a class="{{ html_classes("nav-link", {"active": app.request.get("_route") == path}) }}" href="{{ path(path, parameters) }}">{{ title }}</a>
    </li>
{% endmacro %}

{% block content %}
    <h1 class="mb-3">{{ show.title }}</h1>

    {% include "components/show-badges.twig" with {"show": show} only %}

    <small class="d-block">{{ "shows.count.seasons"|trans({"%count%": show.seasons|length}) }}</small>
    <small class="d-block">{{ "shows.count.episodes"|trans({"%count%": show.totalEpisodes}) }}</small>

    <ul class="nav nav-underline flex-column flex-sm-row mb-3">
        {{ _self.navItem("shows_seasons_page", {"show": show.id}, "shows.seasons"|trans) }}
        {{ _self.navItem("shows_random_episodes_page", {"show": show.id}, "shows.random-episodes"|trans) }}
        {% if is_granted("IS_AUTHENTICATED") %}
            {{ _self.navItem("shows_latest_watched_episodes_page", {"show": show.id}, "shows.latest-watched-episodes"|trans) }}
            {{ _self.navItem("shows_most_watched_episodes_page", {"show": show.id}, "shows.most-watched-episodes"|trans) }}
            {{ _self.navItem("shows_least_watched_episodes_page", {"show": show.id}, "shows.least-watched-episodes"|trans) }}
            {{ _self.navItem("shows_unwatched_episodes_page", {"show": show.id}, "shows.unwatched-episodes"|trans({"%count%": show.getUnwatchedEpisodes(app.user)|length})) }}
        {% endif %}
    </ul>

    {% block showContent %}{% endblock %}
{% endblock %}
