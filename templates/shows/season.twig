{% extends "page.twig" %}

{% block title %}{{ show.title }} - {{ "shows.season"|trans({"%number%":season.number}) }}{% endblock %}

{% block content %}
    <h2><a href="{{ path("shows_show_page", {"show": show.id}) }}" class="text-body-secondary text-decoration-none">{{ show.title }}</a></h2>

    {% include "components/show-badges.twig" with {"show": show} only %}

    <div class="dropdown season-dropdown">
        <h1 class="dropdown-toggle d-inline" type="button" data-bs-toggle="dropdown" aria-expanded="false">{{ "shows.season"|trans({"%number%": season.number}) }}</h1>
        <div class="dropdown-menu">
            {% for season_item in seasons %}
                <a class="{{ html_classes("dropdown-item hoverable-item p-3", {"active": season_item.number == season.number}) }}" href="{{ path("shows_season_page", {"show": show.id, "number": season_item.number}) }}">
                    <div class="d-flex w-100 justify-content-between">
                        <span class="fw-bold">{{ "shows.season"|trans({"%number%": season_item.number}) }}</span>
                        <small class="badge text-bg-secondary rounded-pill">{{ "shows.count.episodes"|trans({"%count%": season_item.episodes|length}) }}</small>
                    </div>
                    <small class="text-body-secondary">{{ season_item.episodes|first.firstAired|format_date }} - {{ season_item.episodes|last.firstAired|format_date }}</small>
                </a>
            {% endfor %}
        </div>
    </div>

    <small class="d-block text-body-secondary my-1"> {{ season.year }}</small>
    <small class="d-block"><i class="fa-solid fa-clock"></i> {{ "runtime"|trans({"%runtime%": season.totalRuntime}) }}</small>

    <h2 class="mb-3">{{ "shows.episodes"|trans }}</h2>

    {% if season.episodes %}
        {% include "components/episode-list-wide.twig" with {"episodes": season.episodes} %}
    {% else %}
        <div class="alert alert-warning">{{ "shows.no-episodes-available"|trans }}</div>
    {% endif %}
{% endblock %}
